---
import BaseLayout from './BaseLayout.astro';
import CTABox from '../components/CTABox.astro';
import ClinicCard from '../components/ClinicCard.astro';
import { clinics, defaultClinic } from '../data/affiliates';

interface Props {
  title: string;
  description: string;
  publishedAt: string;
  updatedAt?: string;
  category: string;
}

const isClinicComparison = Astro.props.category === 'クリニック比較';

const { title, description, publishedAt, updatedAt, category } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-primary-600">ホーム</a>
      <span class="mx-2">/</span>
      <span>{title}</span>
    </nav>

    <article>
      <header class="mb-8">
        <span class="inline-block bg-primary-100 text-primary-700 text-xs font-bold px-3 py-1 rounded mb-3">
          {category}
        </span>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h1>
        <div class="flex items-center gap-4 text-sm text-gray-500">
          <time datetime={publishedAt}>
            公開: {new Date(publishedAt).toLocaleDateString('ja-JP')}
          </time>
          {updatedAt && (
            <time datetime={updatedAt}>
              更新: {new Date(updatedAt).toLocaleDateString('ja-JP')}
            </time>
          )}
        </div>
      </header>

      <div class="prose prose-lg max-w-none">
        <slot />
      </div>

      {isClinicComparison && (
        <div class="mt-12 space-y-6">
          <h2 class="text-2xl font-bold text-gray-900 text-center mb-8">クリニック詳細比較</h2>
          {clinics.map((clinic, i) => (
            <ClinicCard clinic={clinic} rank={i + 1} />
          ))}
        </div>
      )}

      <CTABox
        href={defaultClinic.href}
        title={isClinicComparison ? 'まずは無料の適応検査から' : undefined}
        description={isClinicComparison ? '気になるクリニックが見つかったら、まずは適応検査を受けてみましょう。ほとんどのクリニックで無料です。' : undefined}
      />
    </article>

    <aside class="mt-12 p-6 bg-white rounded-lg shadow-sm">
      <h3 class="font-bold text-lg mb-2">この記事を書いた人</h3>
      <p class="text-sm text-gray-600">
        30代会社員。強度近視（-8D以上）に長年悩まされ、ICL手術を決意。自身の体験をもとに、視力矯正に関する情報を発信しています。
      </p>
    </aside>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": publishedAt,
    "dateModified": updatedAt || publishedAt,
    "author": {
      "@type": "Person",
      "name": "みえるノート編集部"
    },
    "publisher": {
      "@type": "Organization",
      "name": "みえるノート"
    }
  })} />
</BaseLayout>
