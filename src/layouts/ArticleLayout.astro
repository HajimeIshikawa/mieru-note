---
import BaseLayout from './BaseLayout.astro';
import CTABox from '../components/CTABox.astro';
import ClinicCard from '../components/ClinicCard.astro';
import { clinics, defaultClinic } from '../data/affiliates';

interface Props {
  title: string;
  description: string;
  publishedAt: string;
  updatedAt?: string;
  category: string;
}

const isClinicComparison = Astro.props.category === 'クリニック比較';

const { title, description, publishedAt, updatedAt, category } = Astro.props;

const pageUrl = `https://mieru-note.jp${Astro.url.pathname}`;

const categoryStyles: Record<string, { bg: string; text: string; dot: string }> = {
  'ICL': { bg: 'bg-primary-50', text: 'text-primary-800', dot: 'bg-primary-500' },
  'レーシック': { bg: 'bg-emerald-50', text: 'text-emerald-800', dot: 'bg-emerald-500' },
  '体験談': { bg: 'bg-amber-50', text: 'text-amber-800', dot: 'bg-amber-500' },
  '比較': { bg: 'bg-violet-50', text: 'text-violet-800', dot: 'bg-violet-500' },
  '費用': { bg: 'bg-sky-50', text: 'text-sky-800', dot: 'bg-sky-500' },
  'クリニック比較': { bg: 'bg-rose-50', text: 'text-rose-800', dot: 'bg-rose-500' },
};

const style = categoryStyles[category] || { bg: 'bg-gray-50', text: 'text-gray-700', dot: 'bg-gray-400' };
---

<BaseLayout title={title} description={description} ogType="article">
  <div class="max-w-3xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-400 mb-8 flex items-center gap-2">
      <a href="/" class="hover:text-primary-700 transition-colors">ホーム</a>
      <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-gray-600 truncate">{title}</span>
    </nav>

    <article>
      <header class="mb-10">
        <span class={`inline-flex items-center gap-1.5 text-xs font-bold px-2.5 py-1 rounded-full mb-4 ${style.bg} ${style.text}`}>
          <span class={`w-1.5 h-1.5 rounded-full ${style.dot}`}></span>
          {category}
        </span>
        <h1 class="font-display text-3xl md:text-4xl font-semibold text-gray-900 mb-5 leading-tight text-balance">{title}</h1>
        <div class="flex items-center gap-4 text-sm text-gray-400">
          <time datetime={publishedAt} class="tabular-nums">
            {new Date(publishedAt).toLocaleDateString('ja-JP')}
          </time>
          {updatedAt && (
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
              </svg>
              <time datetime={updatedAt} class="tabular-nums">
                {new Date(updatedAt).toLocaleDateString('ja-JP')} 更新
              </time>
            </span>
          )}
        </div>
      </header>

      <div class="prose prose-lg max-w-none">
        <slot />
      </div>

      {isClinicComparison && (
        <div class="mt-14 space-y-6">
          <h2 class="font-display text-2xl font-semibold text-gray-900 text-center mb-8">クリニック詳細比較</h2>
          {clinics.map((clinic, i) => (
            <ClinicCard clinic={clinic} rank={i + 1} />
          ))}
        </div>
      )}

      <CTABox
        href={defaultClinic.href}
        title={isClinicComparison ? 'まずは無料の適応検査から' : undefined}
        description={isClinicComparison ? '気になるクリニックが見つかったら、まずは適応検査を受けてみましょう。ほとんどのクリニックで無料です。' : undefined}
      />
    </article>

    <aside class="mt-14 p-6 bg-white border border-gray-200/80 rounded-xl">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-primary-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
        <div>
          <h3 class="font-display font-semibold text-base mb-1.5 text-gray-900">ミエル</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            30代 PM兼エンジニア。自由診療領域でのプロジェクト経験あり。強度近視（-8D以上）に20年以上悩み、ICL手術を決意。自身の体験と徹底リサーチをもとに情報を発信。
            <a href="/about/" class="text-primary-600 hover:text-primary-800 transition-colors">プロフィール詳細</a>
          </p>
        </div>
      </div>
    </aside>
  </div>

  <!-- JSON-LD: Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": publishedAt,
    "dateModified": updatedAt || publishedAt,
    "author": {
      "@type": "Organization",
      "name": "ミエル",
      "url": "https://mieru-note.jp/about"
    },
    "publisher": {
      "@type": "Organization",
      "name": "みえるノート",
      "url": "https://mieru-note.jp",
      "logo": {
        "@type": "ImageObject",
        "url": "https://mieru-note.jp/og-default.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": pageUrl
    },
    "image": "https://mieru-note.jp/og-default.png",
    "inLanguage": "ja"
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "ホーム",
        "item": "https://mieru-note.jp"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": title
      }
    ]
  })} />

  <!-- JSON-LD: ItemList (クリニック比較記事のみ) -->
  {isClinicComparison && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": title,
      "numberOfItems": clinics.length,
      "itemListElement": clinics.map((clinic, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": clinic.name,
        "url": pageUrl
      }))
    })} />
  )}
</BaseLayout>
