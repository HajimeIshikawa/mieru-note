---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  href?: string;
}

const {
  title = '無料で適応検査を予約する',
  description = 'ICLが自分に合っているか、まずは無料の適応検査で確認してみましょう。',
  buttonText = '適応検査を予約する（無料）',
  href = '#',
} = Astro.props;
---

<div class="my-8 bg-gradient-to-r from-primary-50 to-accent-50 border border-primary-200 rounded-xl p-6 text-center">
  <h3 class="text-xl font-bold text-primary-800 mb-2">{title}</h3>
  <p class="text-gray-600 mb-4">{description}</p>
  <a
    href={href}
    class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-bold py-3 px-8 rounded-lg transition-colors shadow-md hover:shadow-lg no-underline"
    rel="nofollow sponsored"
  >
    {buttonText}
  </a>
  <p class="text-xs text-gray-400 mt-3">※提携クリニックのページに遷移します</p>
</div>
