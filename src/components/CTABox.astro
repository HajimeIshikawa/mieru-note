---
import { defaultClinic } from '../data/affiliates';

interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  href?: string;
}

const {
  title = '無料で適応検査を予約する',
  description = 'ICLが自分に合っているか、まずは無料の適応検査で確認してみましょう。',
  buttonText = '適応検査を予約する（無料）',
  href = defaultClinic.href,
} = Astro.props;
---

<div class="my-10 relative overflow-hidden rounded-xl border border-primary-200 bg-gradient-to-br from-primary-50 via-white to-accent-50/50">
  <div class="absolute top-0 right-0 w-32 h-32 bg-primary-100/30 rounded-full -translate-y-1/2 translate-x-1/2"></div>
  <div class="relative p-7 text-center">
    <h3 class="font-display text-xl font-semibold text-primary-900 mb-2">{title}</h3>
    <p class="text-gray-600 text-sm mb-5 max-w-md mx-auto">{description}</p>
    <a
      href={href}
      class="inline-block bg-primary-700 hover:bg-primary-800 text-white font-bold py-3.5 px-10 rounded-lg transition-all duration-200 shadow-sm hover:shadow-md no-underline text-sm"
      rel="nofollow sponsored"
    >
      {buttonText}
    </a>
    <p class="text-xs text-gray-400 mt-3">※提携クリニックのページに遷移します</p>
  </div>
</div>
