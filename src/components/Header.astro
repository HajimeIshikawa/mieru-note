---
const navItems = [
  { href: '/', label: 'ホーム' },
  { href: '/articles/what-is-icl/', label: 'ICLとは' },
  { href: '/articles/icl-cost/', label: '費用相場' },
  { href: '/articles/icl-vs-lasik/', label: 'ICL vs レーシック' },
  { href: '/articles/icl-clinic-comparison/', label: 'クリニック比較' },
];
---

<header class="bg-white/95 backdrop-blur-sm border-b border-gray-200/60 sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 no-underline group">
      <span class="w-8 h-8 rounded-full bg-primary-700 flex items-center justify-center">
        <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3" />
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
        </svg>
      </span>
      <span class="font-display text-xl font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">
        みえるノート
      </span>
    </a>
    <nav class="hidden md:flex gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-gray-600 hover:text-primary-700 hover:bg-primary-50 transition-colors text-sm font-medium px-3 py-2 rounded-md"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <button
      id="menu-toggle"
      class="md:hidden text-gray-600 p-2 hover:bg-gray-100 rounded-md transition-colors"
      aria-label="メニューを開く"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-4 pb-3">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="block py-2.5 text-gray-600 hover:text-primary-700 text-sm font-medium border-b border-gray-50 last:border-0"
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
