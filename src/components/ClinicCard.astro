---
import type { Clinic } from '../data/affiliates';

interface Props {
  clinic: Clinic;
  rank: number;
}

const { clinic, rank } = Astro.props;
---

<div class={`bg-white rounded-xl border overflow-hidden transition-shadow duration-200 ${clinic.recommended ? 'border-primary-400 shadow-md' : 'border-gray-200 hover:shadow-sm'}`}>
  {clinic.recommended && (
    <div class="bg-primary-700 text-white text-center text-xs font-bold py-2 tracking-wider uppercase">
      当サイトおすすめ
    </div>
  )}
  <div class="p-6">
    <div class="flex items-start justify-between mb-5">
      <div>
        <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-gray-100 text-xs font-bold text-gray-500 mb-2">{rank}</span>
        <h3 class="font-display text-xl font-semibold text-gray-900">{clinic.name}</h3>
      </div>
      <div class="text-right">
        <p class="text-xs text-gray-400 mb-0.5">両眼</p>
        <p class="text-2xl font-bold text-primary-700 tabular-nums">{clinic.cost}</p>
      </div>
    </div>

    <p class="text-gray-600 text-sm mb-5 leading-relaxed">{clinic.description}</p>

    <div class="grid grid-cols-1 gap-2.5 mb-5 text-sm">
      <div class="flex items-start gap-2">
        <span class="text-gray-400 whitespace-nowrap font-medium text-xs mt-0.5 w-10">費用</span>
        <span class="text-gray-700">{clinic.cost}{clinic.costNote && `（${clinic.costNote}）`}</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-gray-400 whitespace-nowrap font-medium text-xs mt-0.5 w-10">保証</span>
        <span class="text-gray-700">{clinic.guarantee}</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-gray-400 whitespace-nowrap font-medium text-xs mt-0.5 w-10">拠点</span>
        <span class="text-gray-700">{clinic.locations}</span>
      </div>
    </div>

    <ul class="space-y-1.5 mb-6">
      {clinic.features.map((feature) => (
        <li class="flex items-center gap-2.5 text-sm text-gray-700">
          <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {feature}
        </li>
      ))}
    </ul>

    <a
      href={clinic.href}
      class="block w-full bg-primary-700 hover:bg-primary-800 text-white font-bold py-3 px-6 rounded-lg text-center transition-all duration-200 no-underline text-sm"
      rel="nofollow sponsored"
    >
      無料適応検査を予約する
    </a>
    <p class="text-xs text-gray-400 mt-2 text-center">※提携クリニックのページに遷移します</p>
  </div>
</div>
