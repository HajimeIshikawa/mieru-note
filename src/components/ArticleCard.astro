---
interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  publishedAt: string;
}

const { title, description, slug, category, publishedAt } = Astro.props;

const categoryColors: Record<string, string> = {
  'ICL': 'bg-blue-100 text-blue-700',
  'レーシック': 'bg-green-100 text-green-700',
  '体験談': 'bg-orange-100 text-orange-700',
  '比較': 'bg-purple-100 text-purple-700',
  '費用': 'bg-yellow-100 text-yellow-700',
  'クリニック比較': 'bg-red-100 text-red-700',
};

const colorClass = categoryColors[category] || 'bg-gray-100 text-gray-700';
---

<a href={`/articles/${slug}`} class="block group no-underline">
  <article class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow p-6 h-full flex flex-col">
    <div class="flex items-center gap-2 mb-3">
      <span class={`text-xs font-bold px-2 py-1 rounded ${colorClass}`}>
        {category}
      </span>
      <time class="text-xs text-gray-400">{publishedAt}</time>
    </div>
    <h3 class="text-lg font-bold text-gray-800 group-hover:text-primary-600 transition-colors mb-2">
      {title}
    </h3>
    <p class="text-sm text-gray-600 flex-grow">
      {description}
    </p>
    <span class="text-primary-600 text-sm font-medium mt-3 inline-flex items-center gap-1">
      続きを読む
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </article>
</a>
